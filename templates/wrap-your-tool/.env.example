# Copy this file to .env.local and fill in. NEVER commit .env.local — keys never go in git or in chat.

# OPTIONAL — only if your tool needs to remember past runs (persistence).
# Get a free Postgres URL at https://neon.tech. Leave blank and the app still runs.
DATABASE_URL=

# OPTIONAL — if your tool calls an external API at runtime, put its key here and
# read it in lib/tool.ts via process.env.YOUR_API_KEY. Add your own as needed.
# YOUR_API_KEY=

# On Vercel: set these in Project -> Settings -> Environment Variables (not in code).
